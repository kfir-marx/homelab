# Managed by Ansible: nut_server
maxretry = 3

[{{ nut_ups_name }}]
    driver = {{ nut_ups_driver }}
    port = {{ nut_ups_port }}
    desc = "{{ nut_ups_description }}"
    vendorid = {{ nut_ups_usb_vendorid | lower }}
    productid = {{ nut_ups_usb_productid | lower }}
{% if nut_ups_usb_serial | length > 0 %}
    serial = {{ nut_ups_usb_serial }}
{% endif %}
{% for option, value in nut_ups_driver_options | dictsort %}
    {{ option }} = {{ value }}
{% endfor %}
